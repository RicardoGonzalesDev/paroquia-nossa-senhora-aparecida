# ─── Notion Integration ───────────────────────────────────────────────────────
# Crie UMA integração em https://www.notion.so/my-integrations
# e compartilhe os três bancos com ela (mesma integração serve todos).

# Token da integração (igual para os dois bancos)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: use "true" apenas para desenvolvimento sem Notion.
# Quando estiver "false" ou ausente, erros de token/ID/permissão falham o build.
USE_NOTION_MOCKS=false

# ── Banco 1: Blog ─────────────────────────────────────────────────────────────
# Database com as colunas: Título, Publicado, Data, Resumo, Categoria, Slug, Capa
NOTION_DATABASE_ID=id_do_banco_blog_aqui

# ── Banco 2: Horários de Missa ────────────────────────────────────────────────
# Database com as colunas: Horário, Dia, Observação, Ativo, Ordem
NOTION_MISSAS_DATABASE_ID=id_do_banco_horarios_aqui

# ── Banco 3: Avisos ───────────────────────────────────────────────────────────
# Database com as colunas: Texto, Ativo, Ordem, Link
NOTION_AVISOS_DATABASE_ID=id_do_banco_avisos_aqui
