---
// src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';
import { getPosts } from '../../lib/notion.js';
import type { Post } from '../../types';

const posts = await getPosts();

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr + 'T12:00:00');
  return d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}

const categories = ['Todas', ...new Set(posts.map((p: Post) => p.category))];
---
<Layout title="Blog" description="Notícias, reflexões e eventos da Paróquia Nossa Senhora Aparecida de Andradas/MG.">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Comunidade & Fé</p>
      <h1>Blog da Paróquia</h1>
      <p class="lead">Notícias, reflexões, eventos e anúncios da nossa comunidade.</p>
    </div>
    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 50" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,30 C480,55 960,5 1440,30 L1440,50 L0,50 Z" fill="#F8F5EF"/>
      </svg>
    </div>
  </section>

  <!-- Filter bar -->
  <section class="blog-section">
    <div class="container">

      <div class="filter-bar" role="group" aria-label="Filtrar por categoria">
        {categories.map(cat => (
          <button class="filter-btn" data-cat={cat === 'Todas' ? 'all' : cat}>
            {cat}
          </button>
        ))}
      </div>

      {posts.length === 0 ? (
        <div class="empty-state">
          <span>✝️</span>
          <h3>Nenhuma publicação encontrada</h3>
          <p>Configure as variáveis <code>NOTION_TOKEN</code> e <code>NOTION_DATABASE_ID</code> no arquivo <code>.env</code> para exibir os posts do Notion.</p>
        </div>
      ) : (
        <div class="posts-grid" id="posts-grid">
          {posts.map((post: Post) => (
            <article class="post-card" data-category={post.category}>
              <div class="post-cover">
                {post.coverUrl
                  ? <img src={post.coverUrl} alt={post.title} loading="lazy" />
                  : <div class="cover-placeholder"><span>✝</span></div>
                }
              </div>
              <div class="post-body">
                <div class="post-meta">
                  <span class="badge">{post.category}</span>
                  <time datetime={post.date}>{formatDate(post.date)}</time>
                </div>
                <h2 class="post-title">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h2>
                {post.summary && <p class="post-summary">{post.summary}</p>}
                <a href={`/blog/${post.slug}`} class="read-more">
                  Ler mais <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}

    </div>
  </section>



</Layout>

<script>
  // Client-side category filter
  const filterBtns = document.querySelectorAll<HTMLElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const cat = btn.dataset.cat;
      cards.forEach(card => {
        const show = cat === 'all' || card.dataset.category === cat;
        card.style.display = show ? '' : 'none';
      });
    });
  });

  // Activate first button by default
  filterBtns[0]?.classList.add('active');
</script>

<style>
/* ─── Page Hero ─────────────────────────────────────────────────────────────── */
.page-hero {
  background: linear-gradient(150deg, #0f2347 0%, var(--azul) 100%);
  padding-block: 4.5rem 3rem;
  position: relative;
  overflow: hidden;
}
.page-hero .eyebrow {
  display: block;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--dourado);
  margin-bottom: 0.75rem;
}
.page-hero h1 {
  font-family: var(--font-display);
  color: var(--branco);
  font-size: clamp(2rem, 4vw, 3rem);
  margin-bottom: 0.75rem;
}
.page-hero .lead {
  color: rgba(255,255,255,0.75);
  max-width: 560px;
  font-size: 1.05rem;
}
.hero-wave { position: absolute; bottom: -1px; left: 0; right: 0; }
.hero-wave svg { width: 100%; display: block; }

/* ─── Blog section ──────────────────────────────────────────────────────────── */
.blog-section { padding-block: 4rem 5rem; }

/* ─── Filter bar ────────────────────────────────────────────────────────────── */
.filter-bar {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}
.filter-btn {
  padding: 0.45rem 1.1rem;
  border-radius: 2rem;
  border: 1.5px solid var(--cinza-cl);
  background: transparent;
  color: var(--cinza);
  font-size: 0.85rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s;
  font-family: var(--font-body);
}
.filter-btn:hover { border-color: var(--azul); color: var(--azul); }
.filter-btn.active { background: var(--azul); border-color: var(--azul); color: var(--branco); }

/* ─── Posts grid ────────────────────────────────────────────────────────────── */
.posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 2rem;
}

.post-card {
  background: var(--branco);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.2s, box-shadow 0.2s;
}
.post-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }

.post-cover { height: 200px; overflow: hidden; }
.post-cover img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
.post-card:hover .post-cover img { transform: scale(1.04); }
.cover-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, var(--azul) 0%, #2B5499 100%);
  display: flex; align-items: center; justify-content: center;
  font-size: 3rem; color: rgba(255,255,255,0.25);
}

.post-body { padding: 1.5rem; display: flex; flex-direction: column; flex: 1; }
.post-meta {
  display: flex; align-items: center; gap: 0.75rem;
  margin-bottom: 0.85rem;
}
.post-meta time { font-size: 0.78rem; color: var(--cinza); }

.post-title {
  font-family: var(--font-display);
  font-size: 1.2rem;
  color: var(--azul);
  margin-bottom: 0.65rem;
  line-height: 1.3;
}
.post-title a { color: inherit; text-decoration: none; }
.post-title a:hover { color: var(--azul-medio); }

.post-summary {
  color: var(--cinza);
  font-size: 0.9rem;
  line-height: 1.65;
  flex: 1;
  margin-bottom: 1.25rem;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.read-more {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--azul-medio);
  text-decoration: none;
  display: inline-flex; align-items: center; gap: 0.35rem;
  transition: gap 0.15s;
  margin-top: auto;
}
.read-more:hover { gap: 0.6rem; text-decoration: none; }

/* ─── Empty state ───────────────────────────────────────────────────────────── */
.empty-state {
  text-align: center;
  padding: 5rem 2rem;
  max-width: 520px;
  margin-inline: auto;
}
.empty-state span { font-size: 3rem; display: block; margin-bottom: 1rem; }
.empty-state h3 { font-family: var(--font-display); color: var(--azul); margin-bottom: 0.75rem; }
.empty-state p { color: var(--cinza); font-size: 0.95rem; line-height: 1.7; }
.empty-state code { background: var(--azul-claro); padding: 0.1em 0.4em; border-radius: 3px; font-size: 0.85em; color: var(--azul); }


</style>
