---
// src/pages/contato.astro
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contato" description="Entre em contato com a Paróquia Nossa Senhora Aparecida de Andradas, Minas Gerais.">

  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Fale conosco</p>
      <h1>Contato</h1>
      <p class="lead">Estamos aqui para acolher você. Entre em contato para sacramentos, dúvidas ou visitas pastorais.</p>
    </div>
    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 50" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,30 C480,55 960,5 1440,30 L1440,50 L0,50 Z" fill="#F8F5EF"/>
      </svg>
    </div>
  </section>

  <section class="contato-section">
    <div class="container contato-grid">

      <!-- Info -->
      <div class="contato-info">
        <h2>Como nos encontrar</h2>

        <div class="info-cards">
          <div class="info-card">
            <span>📍</span>
            <div>
              <strong>Endereço</strong>
              <p>Rua da Paróquia, s/n<br>Centro – Andradas, MG<br>CEP: 37680-000</p>
            </div>
          </div>
          <div class="info-card">
            <span>📞</span>
            <div>
              <strong>Telefone</strong>
              <p>(35) 9999-0000<br>Secretaria: seg–sex, 8h–17h</p>
            </div>
          </div>
          <div class="info-card">
            <span>✉️</span>
            <div>
              <strong>E-mail</strong>
              <p><a href="mailto:paroquia@aparecida-andradas.com.br">paroquia@aparecida-andradas.com.br</a></p>
            </div>
          </div>
          <div class="info-card">
            <span>🕐</span>
            <div>
              <strong>Secretaria</strong>
              <p>Segunda a sexta: 8h–12h e 14h–17h<br>Sábado: 8h–12h</p>
            </div>
          </div>
        </div>

        <div class="map-placeholder">
          <div class="map-inner">
            <span>🗺️</span>
            <p>Andradas, Minas Gerais<br><small>Para chegar: consulte o Google Maps pesquisando "Paróquia Nossa Senhora Aparecida Andradas"</small></p>
            <a href="https://maps.google.com/?q=Andradas+MG" target="_blank" rel="noopener" class="btn btn-primary" style="margin-top:.75rem;font-size:.82rem;">Abrir no Google Maps</a>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="contato-form-wrap">
        <h2>Envie uma mensagem</h2>
        <p class="form-intro">Para sacramentos, agendamentos ou qualquer dúvida, preencha o formulário abaixo. Responderemos em breve.</p>

        <form class="contato-form" id="contato-form">
          <div class="form-group">
            <label for="nome">Seu nome *</label>
            <input type="text" id="nome" name="nome" required placeholder="João da Silva" />
          </div>
          <div class="form-group">
            <label for="email">E-mail *</label>
            <input type="email" id="email" name="email" required placeholder="joao@email.com" />
          </div>
          <div class="form-group">
            <label for="telefone">Telefone</label>
            <input type="tel" id="telefone" name="telefone" placeholder="(35) 99999-0000" />
          </div>
          <div class="form-group">
            <label for="assunto">Assunto *</label>
            <select id="assunto" name="assunto" required>
              <option value="">Selecione...</option>
              <option>Batismo</option>
              <option>Matrimônio</option>
              <option>Crisma</option>
              <option>Unção dos Enfermos</option>
              <option>Informações Gerais</option>
              <option>Outros</option>
            </select>
          </div>
          <div class="form-group full">
            <label for="mensagem">Mensagem *</label>
            <textarea id="mensagem" name="mensagem" required rows="5" placeholder="Escreva sua mensagem aqui..."></textarea>
          </div>
          <div class="full">
            <button type="submit" class="btn btn-primary" style="width:100%">Enviar Mensagem</button>
            <p class="form-note">* Campos obrigatórios. Respondemos em até 2 dias úteis.</p>
          </div>
        </form>
      </div>

    </div>
  </section>

</Layout>

<script>
  document.getElementById('contato-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Mensagem enviada com sucesso! ✝️\n\nEm breve entraremos em contato.');
    (e.target as HTMLFormElement).reset();
  });
</script>

<style>
.page-hero { background:linear-gradient(150deg,#0f2347 0%,var(--azul) 100%); padding-block:4.5rem 3rem; position:relative; overflow:hidden; }
.page-hero .eyebrow { display:block; font-size:.78rem; font-weight:600; letter-spacing:.14em; text-transform:uppercase; color:var(--dourado); margin-bottom:.75rem; }
.page-hero h1 { font-family:var(--font-display); color:var(--branco); font-size:clamp(2rem,4vw,3rem); margin-bottom:.75rem; }
.page-hero .lead { color:rgba(255,255,255,.75); max-width:560px; font-size:1.05rem; }
.hero-wave { position:absolute; bottom:-1px; left:0; right:0; }
.hero-wave svg { width:100%; display:block; }

.contato-section { padding-block:4rem 5rem; }
.contato-grid { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start; }
@media (max-width:860px) { .contato-grid { grid-template-columns:1fr; } }

.contato-info h2, .contato-form-wrap h2 { font-family:var(--font-display); color:var(--azul); font-size:1.75rem; margin-bottom:1.5rem; }
.form-intro { color:var(--cinza); font-size:.9rem; margin-bottom:1.75rem; line-height:1.7; }

.info-cards { display:flex; flex-direction:column; gap:1rem; margin-bottom:2rem; }
.info-card { background:var(--branco); border-radius:var(--radius); box-shadow:var(--shadow); padding:1.25rem; display:flex; gap:1rem; align-items:flex-start; }
.info-card span { font-size:1.5rem; flex-shrink:0; }
.info-card strong { display:block; font-weight:600; color:var(--azul); margin-bottom:.3rem; font-size:.9rem; }
.info-card p { font-size:.85rem; color:var(--cinza); line-height:1.65; margin:0; }
.info-card a { color:var(--azul-medio); }

.map-placeholder {
  background:var(--azul-claro);
  border-radius:var(--radius);
  border:2px dashed var(--cinza-cl);
  min-height:180px;
  display:flex; align-items:center; justify-content:center;
}
.map-inner { text-align:center; padding:2rem; }
.map-inner span { font-size:2.5rem; display:block; margin-bottom:.75rem; }
.map-inner p { font-size:.875rem; color:var(--cinza); line-height:1.6; }
.map-inner small { font-size:.78rem; color:var(--cinza); }

/* Form */
.contato-form-wrap { background:var(--branco); border-radius:var(--radius); box-shadow:var(--shadow); padding:2.5rem; }
.contato-form { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
.form-group { display:flex; flex-direction:column; gap:.45rem; }
.form-group.full, .full { grid-column:1 / -1; }
.form-group label { font-size:.82rem; font-weight:600; color:var(--azul); letter-spacing:.02em; }
.form-group input, .form-group select, .form-group textarea {
  border: 1.5px solid var(--cinza-cl);
  border-radius: var(--radius);
  padding: .65rem .85rem;
  font-family: var(--font-body);
  font-size: .9rem;
  color: var(--texto);
  background: var(--creme);
  transition: border-color .15s, box-shadow .15s;
  outline: none;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
  border-color: var(--azul-medio);
  box-shadow: 0 0 0 3px rgba(43,84,153,.12);
}
.form-group textarea { resize: vertical; min-height: 120px; }
.form-note { font-size:.75rem; color:var(--cinza); margin-top:.65rem; text-align:center; }
@media (max-width:480px) { .contato-form { grid-template-columns:1fr; } }
</style>
